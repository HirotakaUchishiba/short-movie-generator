# 実コスト履歴 (cost_tracking が append-only で書く ローカル運用ファイル)
data/cost_records.jsonl
# バックグラウンドジョブ永続化 (preview_server runtime state)
data/jobs.json
# launchd 起点の fetch_metrics 出力 (= tools/launchd/install.sh が書き出すローカルログ)
data/launchd_*.log
# novel intent suggestion inbox + archive (= UI トリアージ runtime state)
data/intent_suggestions.json
data/intent_suggestions_archive/
data/intent_suggestions.errors.log
assets/bgm/*.wav
assets/bgm/*.mp3
assets/reference_videos/

# Layer 1 (Clip Library) のローカル cache。AI 生成物 (= bg.png + kling_clean.mp4) と
# meta.json を <id>/ 単位で蓄える。生成にコストがかかるため commit せず、
# 各環境で grow_clip_pool.py 等を介して個別に蓄積する。
cache/clips/

