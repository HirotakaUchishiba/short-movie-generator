# Google Gemini (gemini-3-pro-image-preview 背景画像生成)
# https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# ElevenLabs (eleven_v3 日本語TTS)
# https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# fal.ai (Kling V3 Standard I2V 動画生成 / オプションで fal-sync リップシンク)
# https://fal.ai/dashboard/keys
FAL_KEY=

# DomoAI (talking-avatar リップシンク。既定の lipsync provider)
# https://platform.domoai.com/api-keys
DOMOAI_API_KEY=

# リップシンク provider 切替（任意、既定: domoai。fal-sync に戻したい場合のみ）
# LIPSYNC_PROVIDER=fal-sync

# ログ設定（任意）
# LOG_LEVEL=INFO
# LOG_FILE=/path/to/tensyoku.log

# Flask 起動設定（任意）
# FLASK_HOST=127.0.0.1
# FLASK_DEBUG=0
