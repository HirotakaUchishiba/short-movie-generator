# Google Gemini (gemini-3-pro-image-preview 背景画像生成)
# https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# ElevenLabs (eleven_v3 日本語TTS)
# https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# fal.ai (Kling V3 Standard I2V 動画生成 / オプションで fal-sync リップシンク)
# https://fal.ai/dashboard/keys
FAL_KEY=

# Sync.so (lipsync-2 / lipsync-2-pro / sync-3。既定の lipsync provider)
# https://app.sync.so (Dashboard → API Keys)
SYNC_API_KEY=

# DomoAI (talking-avatar リップシンク。代替 provider)
# https://platform.domoai.com/api-keys
DOMOAI_API_KEY=

# リップシンク provider 切替（任意、既定: syncso）
# 候補: syncso (sync.so 公式) / domoai / fal-sync
# LIPSYNC_PROVIDER=domoai

# Sync.so のモデル切替（任意、既定: lipsync-2）
# 候補: lipsync-2 / lipsync-2-pro / lipsync-1.9.0-beta / react-1 / sync-3
# SYNCSO_LIPSYNC_MODEL=lipsync-2-pro

# animation_prompt を lines/emotion/delivery/acoustic + Stage 3 の bg 画像
# (Vision) から Claude Sonnet で自動生成する機能のオン/オフ。既定 true。
# OFF にすると常に手書きまたは background_prompt フォールバックを使う。
# bg 画像参照は Stage 3 完了後に自動でオン (= bg がなければテキストのみで縮退)。
# bg 再生成すると auto_prompts キャッシュは自動で無効化される。
# AUTO_ANIMATION_PROMPT_ENABLED=true
# AUTO_ANIMATION_PROMPT_MODEL=claude-sonnet-4-6

# YouTube Data API v3 公開統計取得用 (要 https://console.cloud.google.com で発行)
# YOUTUBE_API_KEY=

# YouTube OAuth (Analytics API + Upload API。OAuth Playground で refresh_token 発行)
# scope: youtube.upload + yt-analytics.readonly (+ youtube.readonly があると channel guard が完全動作)
# YOUTUBE_OAUTH_CLIENT_ID=
# YOUTUBE_OAUTH_CLIENT_SECRET=
# YOUTUBE_REFRESH_TOKEN=

# 投稿先チャンネル切替 (任意)。YOUTUBE_PROFILE=BRAND を設定すると、各 env の suffix 付き
# (= YOUTUBE_OAUTH_CLIENT_ID_BRAND など) を優先して読む。複数チャンネルを切替えたいときに使う。
# 未設定なら従来通り suffix なし env を読む (= 1 チャンネル運用なら設定不要)。
# CLI からは python3 main.py --resume <TS> --publish youtube --channel BRAND で一回限り override 可。
# YOUTUBE_PROFILE=
# YOUTUBE_OAUTH_CLIENT_ID_BRAND=
# YOUTUBE_OAUTH_CLIENT_SECRET_BRAND=
# YOUTUBE_REFRESH_TOKEN_BRAND=

# ログ設定（任意）
# LOG_LEVEL=INFO
# LOG_FILE=/path/to/tensyoku.log

# Flask 起動設定（任意）
# FLASK_HOST=127.0.0.1
# FLASK_DEBUG=0
