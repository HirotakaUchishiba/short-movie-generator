# Google Gemini (gemini-3-pro-image-preview 背景画像生成)
# https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# ElevenLabs (eleven_v3 日本語TTS)
# https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# fal.ai (Kling V3 Standard I2V 動画生成 / オプションで fal-sync リップシンク)
# https://fal.ai/dashboard/keys
FAL_KEY=

# Sync.so (lipsync-2 / lipsync-2-pro / sync-3。既定の lipsync provider)
# https://app.sync.so (Dashboard → API Keys)
SYNC_API_KEY=

# DomoAI (talking-avatar リップシンク。代替 provider)
# https://platform.domoai.com/api-keys
DOMOAI_API_KEY=

# リップシンク provider 切替（任意、既定: syncso）
# 候補: syncso (sync.so 公式) / domoai / fal-sync
# LIPSYNC_PROVIDER=domoai

# Sync.so のモデル切替（任意、既定: lipsync-2）
# 候補: lipsync-2 / lipsync-2-pro / lipsync-1.9.0-beta / react-1 / sync-3
# SYNCSO_LIPSYNC_MODEL=lipsync-2-pro

# animation_prompt を lines/emotion/delivery/acoustic から Claude Sonnet で
# 自動生成する機能のオン/オフ。既定 true。OFF にすると常に手書きまたは
# background_prompt フォールバックを使う。
# AUTO_ANIMATION_PROMPT_ENABLED=true
# AUTO_ANIMATION_PROMPT_MODEL=claude-sonnet-4-6

# ログ設定（任意）
# LOG_LEVEL=INFO
# LOG_FILE=/path/to/tensyoku.log

# Flask 起動設定（任意）
# FLASK_HOST=127.0.0.1
# FLASK_DEBUG=0
